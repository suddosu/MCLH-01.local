#
# openssl_legacy.cnf
# Разрешает TLS 1.0 и слабые шифры для старого Android SSL-стека.
# Используется через переменную окружения:
#   export OPENSSL_CONF=/opt/cloud/openssl_legacy.cnf
#
# Без этого Python-tlsproxy на OpenSSL 1.1.1 отвергает ClientHello от
# it.takeoff.lytcentral с ошибкой 'unsupported protocol' / SSLv3-подобным
# handshake, который приложение шлёт.

openssl_conf = openssl_init

[openssl_init]
ssl_conf = ssl_sect

[ssl_sect]
system_default = system_default_sect

[system_default_sect]
MinProtocol = TLSv1
CipherString = DEFAULT:@SECLEVEL=0
Options = UnsafeLegacyRenegotiation
